{
  "name": "ptcgp-deck-builder",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "format": "biome format --write .",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "check:links": "node scripts/check-doc-links.mjs",
    "fetch:set": "node --disable-warning=MODULE_TYPELESS_PACKAGE_JSON scripts/fetch-set-data.mjs",
    "validate:set": "node --disable-warning=MODULE_TYPELESS_PACKAGE_JSON scripts/validate-set-data.mjs",
    "typecheck": "tsc --noEmit",
    "test:unit": "vitest run",
    "test:e2e": "playwright test && node scripts/check-scenario-coverage.mjs",
    "test:e2e:coverage": "playwright test && node scripts/check-scenario-coverage.mjs --gate-must"
  },
  "dependencies": {
    "@sentry/nextjs": "^10.63.0",
    "@tanstack/react-virtual": "^3.14.5",
    "next": "^16.2.10",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "server-only": "^0.0.1",
    "zod": "^4.4.3",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.2",
    "@playwright/test": "^1.61.1",
    "@types/node": "^26.1.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  },
  "engines": {
    "node": ">=22"
  }
}
